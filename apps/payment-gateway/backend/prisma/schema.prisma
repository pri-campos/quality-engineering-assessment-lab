generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Payment {
  id               String   @id
  userId           String
  amount           Int
  currency         String
  status           String
  idempotencyKey   String?  @unique
  creditCardToken  String?
  history          Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}